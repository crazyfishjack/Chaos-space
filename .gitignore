# Git 忽略文件配置
# 此文件指定哪些文件/目录不应该被 Git 跟踪

# ============================================
# 敏感信息文件
# ============================================
.env
.env.local
.env.*.local
*.pem
*.key

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================
# 虚拟环境
# ============================================
venv/
ENV/
env/
.venv

# ============================================
# IDE 编辑器
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# 日志文件
# ============================================
*.log
logs/
log/

# ============================================
# 数据文件（运行时生成）
# ============================================
backend/data/*.json
!backend/data/.gitkeep

# ============================================
# 测试相关
# ============================================
.coverage
.pytest_cache/
.tox/
htmlcov/

# ============================================
# Docker
# ============================================
.dockerignore

# ============================================
# 微信开发者工具
# ============================================
project.private.config.json
